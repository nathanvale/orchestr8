{
  "name": "@orchestr8/monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.10.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:ci": "turbo test -- --run",
    "lint": "turbo lint",
    "lint:root": "eslint . --max-warnings 0",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules/.cache",
    "clean:all": "pnpm clean && rm -rf node_modules",
    "fresh": "pnpm clean:all && pnpm install",
    "check": "turbo format:check lint type-check && turbo test -- --run",
    "prepare": "husky",
    "setup:hooks": "node scripts/setup-git-hooks.mjs",
    "example:pr-auto-fix": "tsx scripts/examples/pr-auto-fix-gh.ts",
    "example:pr-lifecycle": "tsx scripts/examples/pr-lifecycle-gh.ts",
    "example:convex-seed": "tsx scripts/examples/convex-seed-init.ts",
    "example:multi-llm": "tsx scripts/examples/multi-llm-fanout-aggregate.ts",
    "example:core:quick-start": "tsx scripts/examples/core-quick-start.ts",
    "example:core:fallback-retry": "tsx scripts/examples/core-fallback-retry.ts",
    "example:core:conditions-env": "tsx scripts/examples/core-conditions-env.ts",
    "validate:dual-consumption": "node scripts/validate-dual-consumption.js",
    "release:publish": "changeset publish",
    "test:release-workflow": "node scripts/test-release-workflow.js"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.6",
    "@eslint/js": "^9.30.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@wallabyjs/cli": "^1.0.8",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-perfectionist": "^4.15.0",
    "glob": "^11.0.3",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.10",
    "msw": "^2.10.2",
    "prettier": "3.6.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@orchestr8/resilience": "link:packages/resilience"
  },
  "lint-staged": {
    "packages/*/src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --cache",
      "bash -c 'PKG=$(echo \"$0\" | sed \"s|.*/packages/\\([^/]*\\)/.*|\\1|\") && cd packages/$PKG && pnpm type-check'"
    ],
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix --cache"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
