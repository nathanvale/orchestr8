{
  "name": "@orchestr8/monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:ci": "turbo test -- --run",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "clean:all": "pnpm clean && rm -rf node_modules",
    "fresh": "pnpm clean:all && pnpm install",
    "check": "turbo format:check lint type-check && turbo test -- --run"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "@types/node": "^24.0.8",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-perfectionist": "^4.15.0",
    "msw": "^2.10.2",
    "prettier": "3.6.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
