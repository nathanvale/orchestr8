{
  "name": "@orchestr8/cli",
  "version": "0.2.1",
  "description": "Command-line interface for @orchestr8 workflow orchestration and automation",
  "keywords": [
    "orchestr8",
    "cli",
    "workflow",
    "automation",
    "orchestration",
    "command-line"
  ],
  "author": "Nathan Vale <nathanvale@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nathanvale/orchestr8.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/nathanvale/orchestr8/tree/main/packages/cli",
  "bugs": {
    "url": "https://github.com/nathanvale/orchestr8/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "o8": "./dist/esm/cli.js",
    "orchestr8": "./dist/esm/cli.js"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:clean && npm run build:esm && npm run build:types",
    "build:clean": "rimraf dist *.tsbuildinfo",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "echo 'CJS build disabled for CLI package'",
    "build:types": "tsc -p tsconfig.types.json",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:ci": "vitest --run",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "format:check": "prettier --check src",
    "clean": "rimraf dist *.tsbuildinfo",
    "prepublishOnly": "node ../../scripts/prepare-publish.cjs clean",
    "postpublish": "node ../../scripts/prepare-publish.cjs restore",
    "lint:fix": "eslint src --fix --max-warnings 0"
  },
  "dependencies": {
    "@orchestr8/core": "workspace:*",
    "@orchestr8/schema": "workspace:*",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
