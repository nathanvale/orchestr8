{
  "name": "@orchestr8/logger",
  "version": "2.0.0",
  "description": "Structured logging for @orchestr8 with redaction and correlation support",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:clean && npm run build:esm && npm run build:cjs && npm run build:types",
    "build:clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "build:types": "tsc -p tsconfig.types.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "node ../../scripts/prepare-publish.cjs clean",
    "postpublish": "node ../../scripts/prepare-publish.cjs restore"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@vitest/coverage-v8": "^3.2.4",
    "pino": "^9.5.0",
    "typescript": "^5.6.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "pino": "^9.0.0"
  },
  "peerDependenciesMeta": {
    "pino": {
      "optional": true
    }
  },
  "keywords": [
    "orchestr8",
    "logging",
    "structured-logging",
    "json",
    "redaction",
    "correlation"
  ],
  "author": "Nathan Vale",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nathanvale/orchestr8.git",
    "directory": "packages/logger"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
