{
  "name": "@orchestr8/testing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "scripts": {
    "build": "npm run build:clean && npm run build:esm && npm run build:cjs && npm run build:types",
    "build:clean": "rimraf dist *.tsbuildinfo",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "build:types": "tsc -p tsconfig.types.json",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:ci": "vitest --run",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "format:check": "prettier --check src",
    "clean": "rimraf dist *.tsbuildinfo",
    "lint:fix": "eslint src --fix --max-warnings 0"
  },
  "dependencies": {
    "@orchestr8/agent-base": "workspace:*",
    "@orchestr8/schema": "workspace:*",
    "msw": "^2.10.2"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@types/yaml": "^1.9.7",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "yaml": "^2.8.1"
  }
}
