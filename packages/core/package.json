{
  "name": "@orchestr8/core",
  "version": "0.3.0",
  "description": "Core orchestration engine for @orchestr8 with workflow execution and event management",
  "keywords": [
    "orchestr8",
    "orchestration",
    "workflow",
    "automation",
    "events",
    "execution"
  ],
  "author": "Nathan Vale <nathanvale@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nathanvale/orchestr8.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/nathanvale/orchestr8/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/nathanvale/orchestr8/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:clean && npm run build:esm && npm run build:cjs && npm run build:types",
    "build:clean": "rimraf dist *.tsbuildinfo",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "build:types": "tsc -p tsconfig.types.json",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:ci": "vitest --run",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix --max-warnings 0",
    "type-check": "tsc --noEmit",
    "format:check": "prettier --check src",
    "clean": "rimraf dist *.tsbuildinfo",
    "prepublishOnly": "node ../../scripts/prepare-publish.cjs clean",
    "postpublish": "node ../../scripts/prepare-publish.cjs restore"
  },
  "dependencies": {
    "@orchestr8/logger": "workspace:*",
    "@orchestr8/schema": "workspace:*",
    "jmespath": "^0.16.0"
  },
  "devDependencies": {
    "@orchestr8/resilience": "workspace:*",
    "@types/jmespath": "^0.15.2",
    "@types/node": "^22.5.5",
    "fast-check": "^3.23.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
